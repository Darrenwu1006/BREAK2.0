{
  "name": "breaktcg",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch:official": "node tools/fetch-official-cards.mjs",
    "import:csv": "node tools/import-csv.mjs",
    "merge:official": "node tools/merge-official.mjs",
    "apply:effects": "node tools/apply-effects.mjs",
    "data:rebuild": "node tools/import-csv.mjs && node tools/merge-official.mjs && node tools/apply-effects.mjs",
    "benchmark:m8": "vite-node src/ai/benchmark-cli.ts",
    "analyze:m8": "vite-node src/ai/deck-analyzer-cli.ts",
    "optimize:m8": "vite-node src/ai/deck-optimizer-cli.ts",
    "analyze:replay": "vite-node tools/analyze-saved-replay.ts",
    "fit:rollout-value": "vite-node src/ai/rollout-value-fit.ts"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  }
}
